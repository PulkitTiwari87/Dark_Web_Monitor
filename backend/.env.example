# Backend Environment Configuration Example
# RENAME this file to .env before running locally.

# MongoDB Connection String (Atlas or Local)
# Ensure you whitelist your server/deployment IP in Atlas!
MONGODB_URL="mongodb+srv://<username>:<password>@cluster0.exmaple.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0"

# Application Security Key for JWT Auth (Must be 32+ characters)
# Generate via: openssl rand -hex 32
SECRET_KEY="replace-this-with-a-very-secure-random-string"

# JWT Token Expiration (Minutes)
ACCESS_TOKEN_EXPIRE_MINUTES="1440"
